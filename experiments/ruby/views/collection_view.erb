<div class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-12">
        <a href="/collections" class="text-sm text-zinc-500 hover:text-white transition-colors flex items-center gap-1 mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Back to Collections
        </a>
        <h1 class="text-4xl font-bold text-white"><%= @collection[:name] %></h1>
    </div>

    <% if @videos.empty? %>
        <div class="border-2 border-dashed border-zinc-800 rounded-3xl p-20 text-center">
            <p class="text-zinc-500 mb-4">No videos in this collection.</p>
            <p class="text-sm text-zinc-600">Go to your dashboard to add videos to collections.</p>
        </div>
    <% else %>
        <div class="grid md:grid-cols-3 gap-8">
            <% @videos.each do |video| %>
                <a href="/videos/<%= video[:id] %>" class="group block bg-zinc-900 border border-zinc-800 rounded-3xl overflow-hidden hover:border-red-600/50 transition-all shadow-lg">
                    <div class="aspect-video relative overflow-hidden">
                        <img src="<%= video[:thumbnail_url] %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="<%= video[:title] %>">
                    </div>
                    <div class="p-5">
                        <h3 class="font-bold text-white line-clamp-2 mb-2"><%= video[:title] %></h3>
                        <p class="text-xs text-zinc-500"><%= video[:channel_name] %></p>
                    </div>
                </a>
            <% end %>
        </div>
    <% end %>
</div>
