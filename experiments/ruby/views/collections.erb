<div class="max-w-7xl mx-auto px-4 py-12">
    <div class="flex justify-between items-center mb-12">
        <h1 class="text-3xl font-bold text-white">Your Collections</h1>
        <button onclick="document.getElementById('new-collection-modal').classList.remove('hidden')" class="px-6 py-2 bg-red-600 hover:bg-red-500 text-white rounded-xl font-bold text-sm shadow-lg transition-all">
            + New Collection
        </button>
    </div>

    <% if @collections.empty? %>
        <div class="border-2 border-dashed border-zinc-800 rounded-3xl p-20 text-center">
            <p class="text-zinc-500 mb-4">No collections yet.</p>
            <p class="text-sm text-zinc-600">Group your videos by topic to stay organized.</p>
        </div>
    <% else %>
        <div class="grid md:grid-cols-3 gap-8">
            <% @collections.each do |collection| %>
                <a href="/collections/<%= collection[:id] %>" class="group bg-zinc-900 border border-zinc-800 p-8 rounded-3xl hover:border-zinc-700 transition-all shadow-xl">
                    <div class="w-12 h-12 bg-zinc-800 rounded-2xl flex items-center justify-center mb-6 text-zinc-500 group-hover:text-red-500 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2"><%= collection[:name] %></h3>
                    <p class="text-sm text-zinc-500">View Collection &rarr;</p>
                </a>
            <% end %>
        </div>
    <% end %>
</div>

<!-- Modal -->
<div id="new-collection-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl w-full max-w-md p-8 shadow-2xl">
        <h2 class="text-2xl font-bold text-white mb-6">Create Collection</h2>
        <form action="/collections" method="POST" class="space-y-6">
            <div>
                <label class="block text-xs font-bold text-zinc-500 uppercase tracking-widest mb-2">Collection Name</label>
                <input type="text" name="name" placeholder="e.g. Ruby on Rails, Fitness, DSA" required class="w-full bg-zinc-950 border border-zinc-800 rounded-xl p-4 text-white placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-red-600/50 focus:border-red-600 transition-all">
            </div>
            <div class="flex gap-4">
                <button type="button" onclick="document.getElementById('new-collection-modal').classList.add('hidden')" class="flex-1 py-3 border border-zinc-800 rounded-xl text-white font-bold text-sm hover:bg-zinc-800 transition-all">
                    Cancel
                </button>
                <button type="submit" class="flex-1 py-3 bg-red-600 hover:bg-red-500 text-white rounded-xl font-bold text-sm shadow-lg shadow-red-600/20 transition-all">
                    Create
                </button>
            </div>
        </form>
    </div>
</div>
