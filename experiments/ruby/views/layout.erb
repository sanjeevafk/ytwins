<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FocusTube - Distraction-Free Learning</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen">
    <nav class="border-b border-zinc-800 bg-zinc-900/50 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                    </div>
                    <span class="text-xl font-bold tracking-tight">FocusTube</span>
                </div>
                <div>
                    <% if session[:user_id] %>
                        <a href="/logout" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">Logout</a>
                    <% else %>
                        <a href="/auth/google" class="inline-flex items-center px-4 py-2 border border-zinc-700 rounded-full text-sm font-medium bg-zinc-800 hover:bg-zinc-700 transition-all shadow-lg hover:shadow-red-500/10">
                            Sign in with Google
                        </a>
                    <% end %>
                </div>
            </div>
        </div>
    </nav>

    <main>
        <%== yield %>
    </main>

    <footer class="border-t border-zinc-900 py-12 mt-20">
        <div class="max-w-7xl mx-auto px-4 text-center text-zinc-500 text-sm">
            &copy; 2026 FocusTube. Built for focused learners.
        </div>
    </footer>
</body>
</html>
