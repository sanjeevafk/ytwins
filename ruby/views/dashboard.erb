<div class="max-w-7xl mx-auto px-4 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
        <div>
            <h1 class="text-3xl font-bold text-white mb-2">Welcome back, <%= @user[:name] %></h1>
            <p class="text-zinc-400">Ready to learn something new today?</p>
        </div>
        <div class="flex items-center gap-4">
            <img src="<%= @user[:avatar_url] %>" class="w-12 h-12 rounded-full border-2 border-zinc-800 shadow-lg" alt="Avatar">
            <div class="hidden sm:block">
                <p class="text-sm font-medium text-white"><%= @user[:name] %></p>
                <p class="text-xs text-zinc-500"><%= @user[:email] %></p>
            </div>
        </div>
    </div>

    <!-- Import Bar -->
    <div class="bg-zinc-900 border border-zinc-800 p-6 rounded-3xl mb-12 shadow-2xl">
        <form action="/videos/import" method="POST" class="flex flex-col sm:flex-row gap-4">
            <div class="flex-1 relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-zinc-500" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                </div>
                <input type="text" name="youtube_url" placeholder="Paste YouTube video URL here..." class="block w-full pl-12 pr-4 py-4 bg-zinc-950 border border-zinc-800 rounded-2xl text-white placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-red-600/50 focus:border-red-600 transition-all">
            </div>
            <button type="submit" class="px-8 py-4 bg-red-600 hover:bg-red-500 text-white rounded-2xl font-bold shadow-lg shadow-red-600/20 transition-all">
                Import Video
            </button>
        </form>
    </div>

    <div class="grid lg:grid-cols-3 gap-12">
        <!-- Main Content: Videos -->
        <div class="lg:col-span-2">
            <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                <svg class="w-5 h-5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                Recent Videos
            </h2>
            
            <% if @videos.empty? %>
                <!-- Empty State -->
                <div class="border-2 border-dashed border-zinc-800 rounded-3xl p-12 text-center">
                    <p class="text-zinc-500 mb-4">No videos imported yet.</p>
                    <p class="text-sm text-zinc-600">Start by pasting a YouTube link above.</p>
                </div>
            <% else %>
                <div class="grid sm:grid-cols-2 gap-6">
                    <% @videos.each do |video| %>
                        <a href="/videos/<%= video[:id] %>" class="group block bg-zinc-900 border border-zinc-800 rounded-3xl overflow-hidden hover:border-red-600/50 transition-all shadow-lg">
                            <div class="aspect-video relative overflow-hidden">
                                <img src="<%= video[:thumbnail_url] %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="<%= video[:title] %>">
                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                                <div class="absolute bottom-3 right-3 px-2 py-1 bg-black/80 rounded text-[10px] font-bold text-white backdrop-blur-sm">
                                    VIDEO
                                </div>
                            </div>
                            <div class="p-5">
                                <h3 class="font-bold text-white line-clamp-2 group-hover:text-red-500 transition-colors mb-2"><%= video[:title] %></h3>
                                <p class="text-xs text-zinc-500"><%= video[:channel_name] %></p>
                            </div>
                        </a>
                    <% end %>
                </div>
            <% end %>
        </div>

        <!-- Sidebar: Collections & Reviews -->
        <div class="space-y-12">
            <div>
                <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    Collections
                </h2>
                <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6">
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-sm text-zinc-400">Total Collections</span>
                        <span class="px-2 py-1 bg-zinc-800 text-zinc-500 text-xs font-bold rounded-lg"><%= @collections.count %></span>
                    </div>
                    <a href="/collections" class="text-sm text-red-500 font-bold hover:text-red-400 transition-colors">Manage Collections &rarr;</a>
                </div>
            </div>

            <div>
                <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Review Queue
                </h2>
                <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6">
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-sm text-zinc-400">Due Today</span>
                        <span class="px-2 py-1 <%= @due_count > 0 ? 'bg-red-600/20 text-red-500' : 'bg-zinc-800 text-zinc-500' %> text-xs font-bold rounded-lg"><%= @due_count %> notes</span>
                    </div>
                    <a href="/review" class="block w-full py-3 <%= @due_count > 0 ? 'bg-red-600 hover:bg-red-500 shadow-red-600/20' : 'bg-zinc-800 hover:bg-zinc-700' %> text-white text-center rounded-xl text-sm font-bold transition-all shadow-lg">
                        Start Session
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
