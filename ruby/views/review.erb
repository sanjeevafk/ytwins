<div class="max-w-3xl mx-auto px-4 py-20">
    <div class="mb-12 flex justify-between items-end">
        <div>
            <h1 class="text-3xl font-bold text-white mb-2">Review Session</h1>
            <p class="text-zinc-500">Recalling what you learned.</p>
        </div>
        <div class="text-right">
            <span class="text-xs font-bold text-zinc-600 uppercase tracking-widest">Cards Remaining</span>
            <p class="text-2xl font-bold text-white"><%= @total_due %></p>
        </div>
    </div>

    <div class="bg-zinc-900 border border-zinc-800 rounded-[3rem] p-12 shadow-2xl relative overflow-hidden">
        <!-- Progress Bar -->
        <div class="absolute top-0 left-0 w-full h-1 bg-zinc-800">
            <div class="h-full bg-red-600 transition-all duration-500" style="width: <%= (1.0 / @total_due * 100).round %>%"></div>
        </div>

        <div class="mb-10">
            <span class="text-xs font-bold text-red-500 bg-red-500/10 px-3 py-1 rounded-full mb-6 inline-block uppercase tracking-wider">
                Note Content
            </span>
            <p class="text-2xl md:text-3xl text-white leading-relaxed font-medium">
                <%= @current_review[:content] %>
            </p>
        </div>

        <div class="pt-10 border-t border-zinc-800">
            <p class="text-sm text-zinc-500 mb-8 text-center italic">How well did you remember this?</p>
            
            <form action="/review/<%= @current_review[:review_id] %>" method="POST" class="grid grid-cols-5 gap-3">
                <% (1..5).each do |q| %>
                    <button type="submit" name="quality" value="<%= q %>" class="group flex flex-col items-center gap-2 p-4 rounded-2xl bg-zinc-950 border border-zinc-800 hover:border-red-600/50 hover:bg-zinc-900 transition-all">
                        <span class="text-lg font-bold text-white group-hover:text-red-500"><%= q %></span>
                        <span class="text-[10px] text-zinc-600 uppercase font-bold"><%= ['Again', 'Hard', 'Good', 'Easy', 'Perfect'][q-1] %></span>
                    </button>
                <% end %>
            </form>
        </div>
    </div>

    <div class="mt-12 text-center">
        <a href="/videos/<%= @current_review[:video_id] %>" class="text-sm text-zinc-500 hover:text-white transition-colors underline underline-offset-4">
            View Source Video
        </a>
    </div>
</div>
