<div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Video Player Column -->
        <div class="lg:flex-1">
            <div class="aspect-video bg-black rounded-3xl overflow-hidden shadow-2xl border border-zinc-800">
                <div id="player"></div>
            </div>
            <div class="mt-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                <div>
                    <h1 class="text-2xl font-bold text-white mb-2"><%= @video[:title] %></h1>
                    <p class="text-zinc-500"><%= @video[:channel_name] %></p>
                </div>
                <div class="flex items-center gap-4">
                    <form action="/collections/add_to_any" method="POST" class="flex gap-2">
                        <input type="hidden" name="video_id" value="<%= @video[:id] %>">
                        <select name="collection_id" class="bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-2 text-sm text-zinc-300 focus:outline-none focus:ring-2 focus:ring-red-600/50">
                            <option value="">Add to Collection...</option>
                            <% @collections.each do |c| %>
                                <option value="<%= c[:id] %>"><%= c[:name] %></option>
                            <% end %>
                        </select>
                        <button type="submit" class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 text-white rounded-xl text-sm font-bold border border-zinc-700">Add</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Notes Column -->
        <div class="lg:w-96 flex flex-col h-[calc(100vh-12rem)] sticky top-24">
            <div class="bg-zinc-900 border border-zinc-800 rounded-3xl flex flex-col h-full overflow-hidden shadow-2xl">
                <div class="p-6 border-b border-zinc-800 flex justify-between items-center">
                    <h2 class="font-bold text-white">Notes</h2>
                    <span class="px-2 py-1 bg-zinc-800 rounded text-[10px] font-bold text-zinc-400 uppercase tracking-wider"><%= @notes.count %> captured</span>
                </div>

                <!-- Notes List -->
                <div id="notes-list" class="flex-1 overflow-y-auto p-6 space-y-4">
                    <% if @notes.empty? %>
                        <div id="no-notes" class="text-center py-12">
                            <p class="text-zinc-600 text-sm">No notes yet.</p>
                            <p class="text-zinc-700 text-xs mt-2">Capture insights as you watch.</p>
                        </div>
                    <% else %>
                        <% @notes.each do |note| %>
                            <div class="group bg-zinc-950 border border-zinc-800 p-4 rounded-2xl hover:border-zinc-700 transition-all cursor-pointer" onclick="seekTo(<%= note[:timestamp_seconds] %>)">
                                <div class="flex justify-between items-start mb-2">
                                    <span class="text-xs font-mono font-bold text-red-500 bg-red-500/10 px-2 py-0.5 rounded">
                                        <%= format_timestamp(note[:timestamp_seconds]) %>
                                    </span>
                                </div>
                                <p class="text-sm text-zinc-300 leading-relaxed"><%= note[:content] %></p>
                            </div>
                        <% end %>
                    <% end %>
                </div>

                <!-- Note Input -->
                <div class="p-6 bg-zinc-950 border-t border-zinc-800">
                    <form id="note-form" class="space-y-3">
                        <input type="hidden" name="video_id" value="<%= @video[:id] %>">
                        <input type="hidden" id="note-timestamp" name="timestamp_seconds" value="0">
                        <textarea id="note-content" name="content" rows="3" placeholder="Type a note..." class="w-full bg-zinc-900 border border-zinc-800 rounded-xl p-3 text-sm text-white placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-red-600/50 focus:border-red-600 transition-all resize-none"></textarea>
                        <div class="flex justify-between items-center">
                            <span id="current-time-display" class="text-xs font-mono text-zinc-500">00:00</span>
                            <button type="submit" class="px-6 py-2 bg-red-600 hover:bg-red-500 text-white rounded-lg text-sm font-bold shadow-lg shadow-red-600/20 transition-all">
                                Capture Note
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://www.youtube.com/iframe_api"></script>
<script>
    let player;
    function onYouTubeIframeAPIReady() {
        player = new YT.Player('player', {
            height: '100%',
            width: '100%',
            videoId: '<%= @video[:youtube_id] %>',
            playerVars: {
                'autoplay': 0,
                'modestbranding': 1,
                'rel': 0
            },
            events: {
                'onReady': onPlayerReady
            }
        });
    }

    function onPlayerReady(event) {
        setInterval(() => {
            const time = Math.floor(player.getCurrentTime());
            document.getElementById('note-timestamp').value = time;
            document.getElementById('current-time-display').innerText = formatTime(time);
        }, 1000);
    }

    function formatTime(seconds) {
        const h = Math.floor(seconds / 3600);
        const m = Math.floor((seconds % 3600) / 60);
        const s = seconds % 60;
        return [h, m, s].map(v => v.toString().padStart(2, '0')).filter((v, i) => v !== '00' || i > 0).join(':');
    }

    function seekTo(seconds) {
        player.seekTo(seconds, true);
    }

    document.getElementById('note-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const content = document.getElementById('note-content').value;
        const timestamp = document.getElementById('note-timestamp').value;
        
        if (!content.trim()) return;

        const res = await fetch('/notes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                video_id: '<%= @video[:id] %>',
                content: content,
                timestamp_seconds: timestamp
            })
        });

        if (res.ok) {
            const note = await res.json();
            addNoteToList(note);
            document.getElementById('note-content').value = '';
        }
    });

    function addNoteToList(note) {
        const list = document.getElementById('notes-list');
        const noNotes = document.getElementById('no-notes');
        if (noNotes) noNotes.remove();

        const div = document.createElement('div');
        div.className = 'group bg-zinc-950 border border-zinc-800 p-4 rounded-2xl hover:border-zinc-700 transition-all cursor-pointer';
        div.onclick = () => seekTo(note.timestamp_seconds);
        div.innerHTML = `
            <div class="flex justify-between items-start mb-2">
                <span class="text-xs font-mono font-bold text-red-500 bg-red-500/10 px-2 py-0.5 rounded">
                    ${formatTime(note.timestamp_seconds)}
                </span>
            </div>
            <p class="text-sm text-zinc-300 leading-relaxed">${note.content}</p>
        `;
        list.appendChild(div);
        list.scrollTop = list.scrollHeight;
    }
</script>
