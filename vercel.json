{
  "version": 2,
  "builds": [
    {
      "src": "fullstack/web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "fullstack/backend/app.rb",
      "use": "@vercel/ruby"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/fullstack/backend/app.rb"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/fullstack/backend/app.rb"
    },
    {
      "source": "/(.*)",
      "destination": "/fullstack/web/$1"
    }
  ]
}
