{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/fullstack/api/app.rb"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/fullstack/api/app.rb"
    },
    {
      "source": "/(.*)",
      "destination": "/fullstack/web/$1"
    }
  ],
  "functions": {
    "fullstack/api/app.rb": {
      "runtime": "@vercel/ruby"
    }
  }
}
